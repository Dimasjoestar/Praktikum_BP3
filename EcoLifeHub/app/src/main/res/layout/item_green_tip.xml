<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTip"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="@dimen/corner_radius_lg"
    app:cardElevation="@dimen/elevation_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Number Badge -->
        <TextView
            android:id="@+id/tvTipNumber"
            android:layout_width="@dimen/icon_size_lg"
            android:layout_height="@dimen/icon_size_lg"
            android:background="@drawable/bg_icon_circle"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/primary_dark"
            android:textSize="@dimen/text_size_subtitle"
            android:textStyle="bold" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/ivTipIcon"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:layout_marginStart="@dimen/spacing_sm"
            android:contentDescription="Tip icon"
            android:visibility="gone"
            app:tint="@color/primary" />

        <!-- Text Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_md"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTipTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tip Title"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTipDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="Tip description"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_body" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
