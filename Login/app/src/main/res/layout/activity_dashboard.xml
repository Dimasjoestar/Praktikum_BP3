<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:id="@+id/main"
    android:background="#F5F5F5"
    tools:context=".DashboardActivity">

    <!-- Judul -->
    <TextView
        android:id="@+id/txtJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard Aplikasi"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#212121"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Menu Profil -->
    <LinearLayout
        android:id="@+id/menuProfil"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_card_blue"
        app:layout_constraintTop_toBottomOf="@id/txtJudul"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menuForm"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_person"
            android:tint="#0288D1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Menu Form -->
    <LinearLayout
        android:id="@+id/menuForm"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_card_orange"
        app:layout_constraintTop_toBottomOf="@id/txtJudul"
        app:layout_constraintStart_toEndOf="@id/menuProfil"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"
        android:layout_marginStart="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_form"
            android:tint="#FB8C00"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Form Pendaftaran"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Menu Informasi -->
    <LinearLayout
        android:id="@+id/menuInfo"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_card_green"
        app:layout_constraintTop_toBottomOf="@id/menuProfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menuPengaturan"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_info"
            android:tint="#43A047"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informasi"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Menu Pengaturan -->
    <LinearLayout
        android:id="@+id/menuPengaturan"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_card_purple"
        app:layout_constraintTop_toBottomOf="@id/menuForm"
        app:layout_constraintStart_toEndOf="@id/menuInfo"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:tint="#8E24AA"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
