<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Green Material3 -->
    <style name="Base.Theme.EcoScanLite" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_primary_dark</item>
        <item name="colorAccent">@color/green_accent</item>
        
        <!-- Material3 color scheme -->
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/green_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/green_primary_dark</item>
        
        <!-- Surface and Background -->
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/green_background</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/green_primary</item>
    </style>

    <style name="Theme.EcoScanLite" parent="Base.Theme.EcoScanLite" />
    
    <!-- Button Style -->
    <style name="GreenButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <!-- Outlined Button Style -->
    <style name="GreenOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
    
    <!-- EditText Style -->
    <style name="GreenEditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/green_primary</item>
        <item name="hintTextColor">@color/green_primary</item>
    </style>
</resources>